# ─── Postgres ──────────────────────────────────────────────
POSTGRES_USER=arena
POSTGRES_PASSWORD=arena
POSTGRES_DB=arena
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────
REDIS_PORT=6379

# ─── API (FastAPI) ─────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://arena:arena@postgres:5432/arena
REDIS_URL=redis://redis:6379/0
SIM_TICK_SECONDS=1.0
SIM_AUTOSEED=true

# ─── Web (Next.js) ─────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/sim
